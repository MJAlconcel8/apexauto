# Copy this file to .env before running the backend.
# Keep .env in the same directory as pom.xml.

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/apexauto_test?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=apexauto_user
SPRING_DATASOURCE_PASSWORD=apexauto_password

# Required. Must be a Base64-encoded 256-bit (32-byte) secret for HS256.
# Generate one with:
#   openssl rand -base64 32
# or:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET_KEY=

# JWT lifetime in milliseconds (1 hour by default).
JWT_EXPIRATION_TIME=3600000

# SMTP email settings (Gmail example).
# For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Chatbot settings. Keep the API key only in this backend file.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
CHATBOT_MAX_OUTPUT_TOKENS=300
